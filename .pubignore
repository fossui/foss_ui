# This file replaces .gitignore when building the pub archive, so it repeats the
# build and tooling excludes. Unanchored patterns match at any depth, covering
# example/ as well. These affect the published archive only.
.dart_tool/
build/
.fvm/
coverage/
staging/
*.log
.DS_Store
pubspec.lock
test/
scripts/
codecov.yml
lefthook.yml
CONTRIBUTING.md
CODE_OF_CONDUCT.md

# Internal maintainer notes. doc/categories/ and dartdoc_options.yaml stay: they
# are dartdoc input. These are unreferenced prose that would otherwise ship unrendered.
doc/components/
doc/tools/
doc/package-size.md
